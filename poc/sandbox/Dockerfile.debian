FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        bubblewrap \
        ca-certificates \
        curl \
        git \
        gnupg \
        procps \
        python3 \
        python3-pip \
        util-linux \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @openai/codex \
    && npm cache clean --force \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY poc/sandbox/verify-sandbox.sh /usr/local/bin/verify-sandbox
RUN chmod +x /usr/local/bin/verify-sandbox

CMD ["/usr/local/bin/verify-sandbox"]
