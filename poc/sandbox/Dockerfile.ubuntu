FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1

ARG CODEX_UID=1000
ARG CODEX_GID=1000

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        bubblewrap \
        ca-certificates \
        curl \
        git \
        gnupg \
        procps \
        python3 \
        python3-pip \
        util-linux \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @openai/codex \
    && npm cache clean --force \
    && rm -rf /var/lib/apt/lists/*

RUN if getent group "${CODEX_GID}" >/dev/null; then \
        EXISTING_GROUP="$(getent group "${CODEX_GID}" | cut -d: -f1)"; \
    else \
        groupadd --gid "${CODEX_GID}" codex; \
        EXISTING_GROUP="codex"; \
    fi \
    && if getent passwd "${CODEX_UID}" >/dev/null; then \
        EXISTING_USER="$(getent passwd "${CODEX_UID}" | cut -d: -f1)"; \
    else \
        useradd --uid "${CODEX_UID}" --gid "${CODEX_GID}" --create-home codex; \
        EXISTING_USER="codex"; \
    fi \
    && mkdir -p /workspace \
    && chown -R "${EXISTING_USER}":"${EXISTING_GROUP}" /workspace /home/"${EXISTING_USER}"

WORKDIR /workspace

COPY poc/sandbox/verify-sandbox.sh /usr/local/bin/verify-sandbox
RUN chmod +x /usr/local/bin/verify-sandbox

USER ${CODEX_UID}:${CODEX_GID}

CMD ["/usr/local/bin/verify-sandbox"]
